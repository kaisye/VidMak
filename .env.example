# VidMak pipeline -- LLM endpoint (OpenAI-compatible).
# The defaults in pipeline/llm.py already point at the local proxy below, so
# you only need a .env (copy this file) if you want to override them.
# The proxy ignores the key value, but the SDK requires it to be non-empty.

VIDMAK_LLM_BASE_URL=http://localhost:20128/v1
VIDMAK_LLM_MODEL=cx/gpt-5.5
VIDMAK_LLM_API_KEY=sk-local
